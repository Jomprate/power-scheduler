{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run App (main.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "noDebug": true,
      "console": "externalTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Run App (with lint check)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "noDebug": true,
      "console": "externalTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "preLaunchTask": "Lint (ruff check)"
    },
    {
      "name": "Debug current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["${relativeFile}"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    },
    {
      "name": "Debug all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["discover", "-s", "src/tests", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    },
    {
      "name": "Debug specific test",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["${input:testPath}"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    }
  ],
  "inputs": [
    {
      "id": "testPath",
      "type": "promptString",
      "description": "Test dotted path, e.g. src.tests.test_systemd_service.SystemdServiceTests.test_cancel",
      "default": ""
    }
  ]
}
